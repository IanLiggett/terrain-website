{
  "name": "Python 3.12 & Django 4.2",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "postCreateCommand": "pip install -r requirements.txt",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  "portsAttributes": {
    "8000": {
      "label": "gunicorn",
      "onAutoForward": "openBrowser"
    },
    "80": {
      "label": "nginx",
      "onAutoForward": "openBrowser"
    }

  }
}
